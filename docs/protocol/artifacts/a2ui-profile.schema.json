{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tkubica12/scalable-ai-chat/docs/protocol/artifacts/a2ui-profile.schema.json",
  "title": "Scalable AI Chat declarative artifact profile",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "mimeType", "version", "surface"],
  "properties": {
    "kind": { "const": "declarative-widget" },
    "mimeType": { "const": "application/vnd.scalable-ai-chat.a2ui+json" },
    "version": { "const": "v1" },
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "components"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "components": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "enum": ["TextBlock", "Card", "Table", "Chart", "Form", "StatusTimeline"] },
              "columns": { "type": "array" },
              "rows": { "type": "array" },
              "chartType": { "enum": ["bar", "line"] },
              "xKey": { "type": "string" },
              "yKey": { "type": "string" },
              "data": { "type": "array" }
            },
            "additionalProperties": true
          }
        }
      }
    }
  }
}
